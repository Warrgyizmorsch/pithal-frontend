                {[{icon:Globe,v:"65+",l:"COUNTRIES"},{icon:MapPin,v:"120+",l:"LOCATIONS"},{icon:Users,v:"250+",l:"EXPERTS"},{icon:Clock,v:"24/7",l:"SUPPORT"}].map((s,i) => (
                  <div key={i} className="flex gap-2.5">
