                <p className="text-[10px] text-slate-100 max-w-lg">We don&apos;t just deliver machines, we build long-term relationships.</p>
              </div>
              <Button variant="primary" className="bg-primary border-primary group" href="/contact">LET&apos;S PARTNER <ArrowRight className="w-3 h-3 transition-transform group-hover:translate-x-1" /></Button>
            </div>
          </Container>
        </section>

        {/* ══════════════════════════════════════════════════════════════════
            SECTION 7 — MANUFACTURING WORKFLOW
            ══════════════════════════════════════════════════════════════════ */}
        <section className="section-space bg-white border-b border-slate-100">
          <Container>
            <div className="text-center max-w-2xl mx-auto mb-12">
              <p className="accent-bars mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-secondary sm:text-[11px]">OUR PROCESS. YOUR ADVANTAGE.</p>
              <h2 className="headline text-[clamp(1.6rem,4.5vw,2.6rem)] text-primary leading-[0.95] mb-3">PRECISELY ENGINEERED.<br /><span className="text-secondary">PERFECTLY DELIVERED.</span></h2>
              <p className="text-sm text-text-muted">From concept to commissioning, our integrated manufacturing & export workflow ensures unmatched quality, reliability and on-time delivery.</p>
            </div>

            <div className="grid sm:grid-cols-2 lg:grid-cols-7 gap-3">
              {workflowSteps.map((s) => (
                <div key={s.id} className="bg-slate-50 border border-slate-100 rounded-lg overflow-hidden group hover:border-secondary/20 hover:shadow-md transition-all">
                  <div className="aspect-[4/3] bg-slate-200 relative overflow-hidden">
                    <Image src={s.image} alt={s.name} fill sizes="150px" className="object-cover transition-transform group-hover:scale-105" />
                    <div className="absolute top-1.5 left-1.5 w-5 h-5 rounded-full bg-secondary text-white font-black text-[9px] flex items-center justify-center">{s.id}</div>
                  </div>
                  <div className="p-3">
                    <div className="flex items-center gap-1 mb-1.5"><s.icon className="w-3 h-3 text-secondary" /><h4 className="text-[9px] font-black text-primary uppercase tracking-wider">{s.name}</h4></div>
                    <ul className="text-[7px] text-slate-800 font-bold uppercase tracking-wider space-y-0.5">
                      {s.bullets.map((b, i) => <li key={i} className="flex items-start gap-0.5"><span className="text-secondary">•</span>{b}</li>)}
                    </ul>
                  </div>
                </div>
              ))}
            </div>

            {/* Delivery flow */}
            <div className="mt-10 bg-slate-50 border border-slate-100 p-6 rounded-lg text-center max-w-3xl mx-auto">
              <h4 className="text-[10px] font-black text-primary uppercase tracking-widest mb-5">BUILT IN INDIA. DELIVERED GLOBALLY.</h4>
              <div className="grid grid-cols-3 md:grid-cols-6 gap-4">
                {[
                  { icon: Building2, t: "DESIGNED IN INDIA" },
                  { icon: Award, t: "SECURE PACKAGING" },
                  { icon: Globe, t: "GLOBAL SHIPPING" },
                  { icon: Truck, t: "35+ COUNTRIES" },
                  { icon: HardHat, t: "INSTALLED" },
                  { icon: Clock, t: "LIFETIME SUPPORT" },
                ].map((f, i) => (
                  <div key={i} className="flex flex-col items-center">
                    <div className="w-10 h-10 rounded-full border-2 border-secondary bg-white text-secondary flex items-center justify-center mb-2"><f.icon className="w-4 h-4" /></div>
                    <div className="text-[7px] font-black text-primary uppercase tracking-wide">{f.t}</div>
                  </div>
                ))}
              </div>
            </div>

            <div className="mt-8 rounded-lg bg-primary text-white p-4 flex flex-col md:flex-row justify-between items-center gap-3 text-[10px] font-bold uppercase tracking-wider">
              <span className="text-secondary flex items-center gap-1"><Check className="w-3.5 h-3.5" /> A PROVEN PROCESS. A PROMISE DELIVERED.</span>
              <span className="text-slate-300">Engineering excellence • Manufacturing precision • Global delivery • Lifetime partnership</span>
            </div>
          </Container>
        </section>

        {/* ══════════════════════════════════════════════════════════════════
            SECTION 8 — CERTIFICATIONS
            ══════════════════════════════════════════════════════════════════ */}
        <section className="section-space bg-primary-dark text-white border-b border-white/5">
          <Container>
            <div className="text-center max-w-2xl mx-auto mb-12">
              <p className="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-secondary sm:text-[11px]">CERTIFIED. COMPLIANT. TRUSTED.</p>
              <h2 className="headline text-[clamp(1.6rem,4.5vw,2.6rem)] leading-[0.95] mb-3">BUILT ON STANDARDS.<br /><span className="text-secondary">DELIVERED WITH CONFIDENCE.</span></h2>
              <p className="text-xs text-slate-300">Our commitment to international quality, safety and compliance ensures every Pithal solution meets global benchmarks.</p>
            </div>

            <div className="grid sm:grid-cols-2 lg:grid-cols-6 gap-3">
              {certifications.map((c, i) => (
                <div key={i} className={cn("bg-primary rounded p-4 border text-center hover:border-secondary/20 transition-colors", c.color)}>
                  <Award className="w-8 h-8 text-secondary mx-auto mb-2" />
                  <h4 className="text-[10px] font-black text-white uppercase tracking-wide">{c.name}</h4>
                  <div className="text-[7px] text-secondary font-bold uppercase tracking-wider mt-0.5">{c.sub}</div>
                  <p className="text-[8px] text-slate-400 mt-1.5">{c.desc}</p>
                </div>
              ))}
            </div>

            <div className="mt-12 pt-8 border-t border-white/5">
              <h3 className="text-[10px] font-black text-secondary uppercase tracking-widest text-center mb-8">INTERNATIONAL STANDARDS WE ADHERE TO</h3>
              <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
                {complianceGrid.map((g, i) => (
                  <div key={i} className="bg-primary rounded-lg p-5 border border-white/5 flex gap-3">
                    <g.icon className="w-5 h-5 text-secondary flex-shrink-0 mt-0.5" />
                    <div>
                      <h4 className="text-[10px] font-black text-white uppercase tracking-wider mb-2">{g.title}</h4>
                      <ul className="text-[8px] text-slate-300 font-bold uppercase tracking-wider space-y-1">
                        {g.items.map((it, j) => <li key={j} className="flex items-start gap-1"><span className="text-secondary">•</span>{it}</li>)}
                      </ul>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </Container>
        </section>

        {/* ══════════════════════════════════════════════════════════════════
            SECTION 9 — PARTNERSHIPS
            ══════════════════════════════════════════════════════════════════ */}
        <section className="section-space bg-white border-b border-slate-100">
          <Container>
            <div className="text-center max-w-2xl mx-auto mb-12">
