                <div className="bg-primary text-white text-[9px] font-black uppercase tracking-wider p-2 rounded mb-3 flex items-center gap-1"><TrendingUp className="w-3 h-3 text-secondary" /> OUR TRUST IN NUMBERS</div>
                <div className="grid grid-cols-2 gap-2 text-center">
                  {[{v:"35+",l:"COUNTRIES"},{v:"1200+",l:"PROJECTS"},{v:"98%",l:"RETENTION"},{v:"50+",l:"EXPERTS"},{v:"24/7",l:"SUPPORT"},{v:"100%",l:"COMMITMENT"}].map((s,i) => (
                    <div key={i} className="bg-slate-50 border border-slate-100 p-2 rounded">
                      <div className="text-sm font-black text-secondary">{s.v}</div>
                      <div className="text-[7px] font-bold text-primary uppercase mt-0.5">{s.l}</div>
