                <div className="grid grid-cols-3 gap-1.5 text-center text-[7px] font-black uppercase text-slate-700">
                  {["THYSSENKRUPP","LAFARGE","HOLCIM","METSO","SANDVIK","CEMEX","VINCI","BARRICK","AFRIMAT"].map((l,i) => (
                    <div key={i} className="bg-slate-50 border border-slate-100 p-1.5 rounded min-h-[32px] flex items-center justify-center">{l}</div>
                  ))}
                </div>
              </div>
              {/* Industries */}
              <div className="lg:col-span-3 bg-white border border-slate-100 p-4 rounded-lg">
                <div className="bg-primary text-white text-[9px] font-black uppercase tracking-wider p-2 rounded mb-3 flex items-center gap-1"><Globe className="w-3 h-3 text-secondary" /> INDUSTRIES SERVED</div>
                <div className="grid grid-cols-2 gap-1.5 text-center text-[8px] font-black uppercase text-slate-700">
                  {["MINING","AGGREGATES","CEMENT","INFRASTRUCTURE","CONSTRUCTION","RECYCLING"].map((ind,i) => (
                    <div key={i} className="bg-slate-50 border border-slate-100 p-2 rounded">{ind}</div>
