                        <circle cx={r.coords.x} cy={r.coords.y} r="5" className="fill-red-500" /><circle cx={r.coords.x} cy={r.coords.y} r="2.5" className="fill-white" />
                      </g>
                    ))}
                    <circle cx="580" cy="180" r="5" className="fill-secondary" />
                  </svg>
                </div>
                <div className="flex gap-4 text-[8px] font-black text-slate-300 border-t border-white/10 pt-2 mt-2">
                  <span className="flex items-center gap-1"><span className="w-2 h-2 rounded-full bg-red-500" /> Hub</span>
                  <span className="flex items-center gap-1"><span className="w-2 h-2 rounded-full bg-emerald-500" /> Center</span>
                  <span className="flex items-center gap-1"><span className="w-2 h-2 rounded-full bg-slate-600" /> Future</span>
                </div>
              </div>
              {/* Zones */}
              <div className="lg:col-span-4 bg-primary rounded-lg border border-white/5 p-5">
                <h3 className="text-[10px] font-black text-secondary uppercase tracking-widest border-b border-white/10 pb-2 mb-3">REGIONAL SUPPORT ZONES</h3>
                {zonesData.map((z,i) => (
                  <div key={i} className="border-b border-white/5 pb-2 mb-2 last:border-0 last:mb-0">
                    <div className="flex justify-between text-[9px] font-black text-white uppercase tracking-wide"><span>{z.region}</span><span className="text-[7px] text-secondary">ACTIVE</span></div>
                    <div className="text-[9px] text-slate-400 font-bold">{z.countries}</div>
                    <div className="text-[8px] text-slate-300">{z.services}</div>
                  </div>
                ))}
              </div>
            </div>

            {/* Response + Growth */}
            <div className="grid lg:grid-cols-12 gap-6 mt-8 pt-8 border-t border-white/5">
              <div className="lg:col-span-5">
                <h4 className="text-[9px] font-black text-secondary uppercase tracking-widest mb-3">OUR SUPPORT STRUCTURE</h4>
                <div className="flex flex-wrap gap-1.5 text-[8px] font-black uppercase text-white">
                  <span>HUBS</span><ArrowRight className="w-3 h-3 text-secondary" /><span>CENTERS</span><ArrowRight className="w-3 h-3 text-secondary" /><span>ENGINEERS</span><ArrowRight className="w-3 h-3 text-secondary" /><span>SITE</span>
                </div>
              </div>
              <div className="lg:col-span-3">
                <h4 className="text-[9px] font-black text-secondary uppercase tracking-widest mb-3">RESPONSE COMMITMENT</h4>
                <div className="space-y-1 text-[9px]">
                  <div className="flex justify-between"><span className="text-slate-400">Availability:</span><span className="font-bold">24/7</span></div>
                  <div className="flex justify-between"><span className="text-slate-400">Initial Response:</span><span className="font-bold">4-8 Hrs</span></div>
                  <div className="flex justify-between"><span className="text-slate-400">On-site:</span><span className="font-bold">24-48 Hrs</span></div>
                  <div className="flex justify-between"><span className="text-slate-400">Fix Rate:</span><span className="font-bold">&gt;95%</span></div>
                </div>
              </div>
              <div className="lg:col-span-4">
                <h4 className="text-[9px] font-black text-secondary uppercase tracking-widest mb-3">FUTURE GROWTH</h4>
                <div className="grid grid-cols-3 gap-2 text-center">
                  {[{v:"20+",l:"Centers"},{v:"150+",l:"Experts"},{v:"40+",l:"Countries"}].map((g,i) => (
                    <div key={i} className="bg-primary p-2 border border-white/5 rounded"><div className="text-xs text-secondary font-black">{g.v}</div><div className="text-[7px] text-slate-400 uppercase">{g.l}</div></div>
                  ))}
                </div>
              </div>
            </div>
          </Container>
        </section>

        {/* ══════════════════════════════════════════════════════════════════
            SECTION 11 — CTA
            ══════════════════════════════════════════════════════════════════ */}
        <section className="bg-gradient-to-b from-slate-50 to-white pt-14 pb-0 lg:pt-20 overflow-hidden">
          <Container>
            <div className="grid lg:grid-cols-12 gap-10 items-center mb-12">
              <div className="lg:col-span-8">
                <p className="accent-bars mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-secondary sm:text-[11px]">YOUR GLOBAL ENGINEERING PARTNER</p>
                <h2 className="headline text-[clamp(1.8rem,5vw,3.2rem)] text-primary leading-[0.9] mb-3">LET&apos;S BUILD<br /><span className="text-secondary">INDUSTRIAL SUCCESS</span><br />ACROSS BORDERS.</h2>
                <p className="text-sm text-text-muted max-w-lg">Pithal Machines is ready to collaborate, engineer and deliver world-class solutions that power industries and build a stronger future together.</p>
              </div>
              <div className="lg:col-span-4 text-right border-l-4 border-secondary pl-5">
                <div className="text-sm font-black text-primary uppercase tracking-wider">PITHAL MACHINES PVT. LTD.</div>
                <div className="text-[10px] text-secondary font-black uppercase">Your Global Engineering Partner</div>
              </div>
            </div>

            <div className="grid sm:grid-cols-2 lg:grid-cols-5 gap-3">
              {[
                { icon: Globe, t: "EXPORT CONSULTATION", d: "Expert guidance for global market success." },
                { icon: Users, t: "GLOBAL PROJECT", d: "Collaborate on large-scale industrial projects." },
                { icon: Settings, t: "ENGINEERING SUPPORT", d: "Technical expertise at every stage." },
                { icon: Handshake, t: "PARTNERSHIP", d: "Build long-term partnerships that create value." },
                { icon: Mail, t: "INQUIRIES", d: "We respond to your global requirements." },
              ].map((s, i) => (
                <div key={i} className="p-4 border border-slate-200 bg-white rounded-lg hover:border-secondary/20 hover:shadow transition-all">
                  <s.icon className="w-5 h-5 text-secondary mb-3" />
                  <div className="text-[9px] font-black text-primary uppercase tracking-wide mb-1">{s.t}</div>
                  <div className="text-[8px] text-text-muted">{s.d}</div>
                </div>
              ))}
            </div>

            {/* Orange banner */}
            <div className="mt-12 rounded-t-xl bg-gradient-to-r from-secondary to-accent text-white p-8 flex flex-col md:flex-row justify-between items-center gap-6">
              <div>
                <div className="text-[10px] font-black uppercase text-primary-dark tracking-widest mb-1">ONE VISION. ONE WORLD. ENDLESS POSSIBILITIES.</div>
                <h4 className="text-lg md:text-xl font-black uppercase leading-none mb-3">Let&apos;s build industrial success across borders.</h4>
                <div className="flex flex-wrap gap-3 text-[8px] font-bold uppercase tracking-wider">
                  <span>✓ GLOBAL REACH</span><span>✓ TRUST & QUALITY</span><span>✓ INNOVATIVE SOLUTIONS</span><span>✓ BUILT TOGETHER</span>
                </div>
              </div>
              <div className="flex flex-col items-end gap-2 flex-shrink-0">
                <div className="text-right text-[10px] font-black uppercase tracking-wider text-primary-dark">Pithal Machines Pvt. Ltd.</div>
                <Button variant="outlineNavy" className="bg-transparent border-white text-white hover:bg-white hover:text-secondary group" href="/contact">
                  LET&apos;S BUILD TOGETHER <ArrowRight className="w-3 h-3 transition-transform group-hover:translate-x-1" />
                </Button>
              </div>
            </div>
          </Container>
