# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# .gitignore
# keep ignoring product images generally, but allow jaw-crusher images needed for the site
public/images/products/
!public/images/products/jaw-crusher/
!public/images/products/jaw-crusher/*
# Or if you just want to ignore large raw assets
*.zip
*.pdf

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
